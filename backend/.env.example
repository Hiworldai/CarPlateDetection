APP_NAME=Car Plate Recognition API
DEBUG=false
DATABASE_URL=mysql+pymysql://root:your_mysql_password@127.0.0.1:3306/car_plate_detection?charset=utf8mb4
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_SECRET=replace_with_a_long_random_secret
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_admin_password
UPLOAD_DIR=./backend/storage
YOLO_MODEL_PATH=./models/best.pt
OCR_CLS_MODEL_DIR=./paddleModels/whl/cls/ch_ppocr_mobile_v2.0_cls_infer
OCR_DET_MODEL_DIR=./paddleModels/whl/det/ch/ch_PP-OCRv4_det_infer
OCR_REC_MODEL_DIR=./paddleModels/whl/rec/ch/ch_PP-OCRv4_rec_infer
FONT_PATH=./Font/platech.ttf
DETECT_CONFIDENCE=0.35
VIDEO_MAX_DURATION_SECONDS=10
VIDEO_MAX_UPLOAD_BYTES=10485760
VIDEO_FRAME_INTERVAL=5
VIDEO_MAX_ANALYSIS_FRAMES=80
VIDEO_PROCESS_MAX_SIDE=1280
DUPLICATE_FRAME_WINDOW=30
